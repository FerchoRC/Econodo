{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/auth/:path*",     "destination": "https://sharkbyte-api-dev.onrender.com/auth/:path*" },
    { "source": "/api/:path*",      "destination": "https://sharkbyte-api-dev.onrender.com/api/:path*" },
    { "source": "/health",          "destination": "https://sharkbyte-api-dev.onrender.com/health" },
    { "source": "/internal/:path*", "destination": "https://sharkbyte-api-dev.onrender.com/internal/:path*" },
    { "source": "/webhooks/:path*", "destination": "https://sharkbyte-api-dev.onrender.com/webhooks/:path*" },
    { "source": "/(.*)",            "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    }
  ]
}
